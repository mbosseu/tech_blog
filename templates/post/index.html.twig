{% extends 'base.html.twig' %}

{% block title %}Tech Blog{% endblock %}

{% block body %}

<div class="text-center mb-5">

<h1 class="display-4 fw-bold">
Tech Blog
</h1>

<p class="text-muted">
Latest articles about IT and development
</p>

</div>


<div class="row">

{% for post in posts %}

<div class="col-md-6 mb-4">

<div class="card post-card p-4">

<h3>

<a href="{{ path('app_post_show', {id: post.id}) }}" class="text-decoration-none text-dark">

{{ post.title }}

</a>

</h3>

<p class="text-muted">

{{ post.content|slice(0,120) }}...

</p>

<a href="{{ path('app_post_show', {id: post.id}) }}" class="btn btn-primary">

Lire l'article

</a>

</div>

</div>

{% endfor %}

</div>

{% endblock %}