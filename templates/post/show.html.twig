{% extends 'base.html.twig' %}

{% block title %}
	{{ post.title }}
{% endblock %}

{% block body %}

	<div class="card post-card p-5 mb-5">

		<h1 class="mb-3">

			{{ post.title }}

		</h1>

		<p class="text-muted">

			{{ post.content }}

		</p>

		<a href="{{ path('app_home') }}" class="btn btn-secondary mt-3">

			Retour au blog

		</a>

	</div>

	<h2 class="mb-4">

		Commentaires

	</h2>

	{% for comment in post.comments %}

		<div class="card p-3 mb-3">

			<strong>

				{{ comment.username }}

			</strong>

			<p>

				{{ comment.content }}

			</p>

		</div>

	{% else %}

		<p class="text-muted">

			Aucun commentaire pour cet article

		</p>

	{% endfor %}

	<hr class="my-5">

	<h3>

		Ajouter un commentaire

	</h3>

	<div class="card p-4">

		{{ form_start(commentForm) }}

		{{ form_row(commentForm.username) }}

		{{ form_row(commentForm.content) }}

		<button class="btn btn-primary mt-3">

			Envoyer

		</button>

		{{ form_end(commentForm) }}

	</div>

{% endblock %}
